# Session Vault — Per-machine configuration
# Copy to config.env and adjust for this machine

# Local cache directory (synced via rclone)
VAULT_LOCAL="$HOME/.session-vault"

# Hostname used for partitioning (auto-detected if empty)
VAULT_HOSTNAME=""

# rclone remote path (must include trailing slash)
RCLONE_REMOTE="jss:"

# Claude projects directory (where JSONL session files live)
CLAUDE_PROJECTS_DIR="$HOME/.claude/projects"

# Claude global history file
CLAUDE_HISTORY="$HOME/.claude/history.jsonl"
